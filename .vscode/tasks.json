{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run KB API",
			"type": "shell",
			"command": ".\\.venv\\Scripts\\python.exe",
			"args": [
				"-m",
				"kb.cli",
				"api"
			],
			"isBackground": true,
			"group": "build"
		},
		{
			"label": "Run KB Frontend",
			"type": "shell",
			"command": "npm",
			"args": [
				"--prefix",
				"frontend",
				"run",
				"dev",
				"--",
				"--host",
				"127.0.0.1"
			],
			"isBackground": true,
			"group": "build"
		}
	]
}