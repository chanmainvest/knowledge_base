# Copy to .env and fill in. NEVER commit .env.

# ---- MacroVoices ----
MACROVOICES_USER=your_user
MACROVOICES_PASS=your_pass

# ---- HKEJ (Hong Kong Economic Journal) ----
HKEJ_USER=your_email
HKEJ_PASS=your_pass

# ---- Patreon (browser session_id cookie; DevTools → Application → Cookies) ----
PATREON_SESSION_ID=

# ---- Substack (browser substack.sid cookie; DevTools → Application → Cookies) ----
# Not required for free publications/posts — only needed to read posts on a
# paid subscription. Prefer `kb substack prime-session` (interactive login,
# saves the cookie for you) over pasting it here.
SUBSTACK_SESSION_COOKIE=

# ---- LLM: pick the default provider `kb extract run` uses, and (separately)
# the provider used for embeddings (only openai/zai support embeddings today) ----
LLM_PROVIDER=openai              # openai | github | anthropic | zai
LLM_EMBEDDING_PROVIDER=openai    # openai | zai

# openai (OpenAI-compatible; also works with Azure OpenAI, local llama.cpp/Ollama
# by pointing LLM_BASE_URL at them)
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini
LLM_EMBEDDING_MODEL=text-embedding-3-small

# github: shells out to the local `copilot` CLI (this tool) in non-interactive
# mode; no API key needed here, just `copilot /login` once on this machine.
GITHUB_CLI_PATH=copilot
GITHUB_MODEL=                    # empty = let the CLI pick its own default
GITHUB_CLI_TIMEOUT_SEC=180

# anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_BASE_URL=              # empty = https://api.anthropic.com
ANTHROPIC_MODEL=claude-sonnet-4-5

# zai (Z.ai / Zhipu GLM, OpenAI-compatible endpoint)
ZAI_API_KEY=...
ZAI_BASE_URL=https://api.z.ai/api/paas/v4
ZAI_MODEL=glm-4.6
ZAI_EMBEDDING_MODEL=embedding-3

# ---- Data directory ----
# Where scraped markdown and raw HTML are stored. Relative paths resolve
# against the repo root; absolute paths are used as-is.
DATA_DIR=data

# ---- Postgres ----
POSTGRES_HOST=localhost
POSTGRES_PORT=5544
POSTGRES_USER=kb
POSTGRES_PASSWORD=kb_local_dev
POSTGRES_DB=kb

# ---- Scraper behaviour ----
SCRAPE_RATE_LIMIT_SEC=3        # min seconds between requests per host
HKEJ_RATE_LIMIT_SEC=5          # HKEJ browser page loads (Camoufox; slower than httpx)
PATREON_RATE_LIMIT_SEC=5       # Patreon internal API requests (min seconds per host)
SUBSTACK_RATE_LIMIT_SEC=3      # Substack public archive/post API (min seconds per host)
YOUTUBE_RATE_LIMIT_SEC=5       # YouTube subtitle/timedtext endpoint 429s hard; adaptive backoff on top
SCRAPE_USER_AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64) KB-Personal/0.1"
SCRAPE_MAX_RETRIES=3
YT_DLP_COOKIES_FROM_BROWSER=   # e.g. "chrome" or "firefox" if a channel needs login
# Optional SOCKS5 proxy for yt-dlp to avoid per-IP rate limiting (HTTP 429).
# Auto-tunnels: comma-separated SSH host aliases — the scraper opens one
# `ssh -D` tunnel per host and round-robins requests across them.
# Available hosts: hevangel.com, oc1/2/3/4.hevangel.com, horace.org, serv00
YT_DLP_PROXY_HOSTS=            # e.g. "oc1.hevangel.com,oc2.hevangel.com,serv00"
# Or a single manual tunnel you've opened yourself (e.g. `ssh -D 1080 -N host`):
YT_DLP_PROXY=                  # e.g. "socks5://127.0.0.1:1080"
PATREON_COOKIES_FROM_BROWSER=  # e.g. "chrome" or "edge" — auto-read session_id cookie
SUBSTACK_COOKIES_FROM_BROWSER= # e.g. "chrome" or "edge" — auto-read substack.sid cookie

# ---- Whisper ASR transcription ----
# For YouTube videos with no subtitle/transcript (has_transcript=false),
# scripts/transcribe_missing.py downloads audio and runs faster-whisper on GPU.
# One video at a time (sequential) to keep GPU thermals in check.
# Audio files are stored in WHISPER_TMP_DIR (gitignored) and deleted after use.
WHISPER_MODEL=large-v3          # faster-whisper model: tiny|base|small|medium|large-v3
WHISPER_DEVICE=cuda             # cuda | cpu
WHISPER_COMPUTE_TYPE=float16    # float16 (GPU), int8 (CPU)
WHISPER_BEAM_SIZE=5             # beam search width (higher = more accurate, slower)
WHISPER_LANGUAGE=               # empty = auto-detect, or "en"/"yue"/"zh"/etc.
WHISPER_MAX_DURATION_SEC=0      # 0 = no limit; otherwise skip videos longer than this (seconds)
WHISPER_TMP_DIR=tmp/audio       # relative to repo root, gitignored

# ---- API ----
API_HOST=127.0.0.1
API_PORT=8088
